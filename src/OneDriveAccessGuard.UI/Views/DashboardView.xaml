<UserControl x:Class="OneDriveAccessGuard.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <TextBlock Text="ダッシュボード" FontSize="20" FontWeight="Medium" Margin="0,0,0,24"/>

                <!-- 統計カード -->
                <WrapPanel Margin="0,0,0,24">

                    <!-- 全共有ファイル数 -->
                    <Border Width="180" Height="100" Margin="0,0,16,16" CornerRadius="8"
                            Background="#E3F2FD">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalSharedFilesCount}" FontSize="36" FontWeight="Bold"
                                       Foreground="#1565C0" HorizontalAlignment="Center"/>
                            <TextBlock Text="全共有ファイル数" FontSize="13" Foreground="#1565C0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- ユニーク教職員数 -->
                    <Border Width="180" Height="100" Margin="0,0,16,16" CornerRadius="8"
                            Background="#E8F5E9">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding UniqueOwnersCount}" FontSize="36" FontWeight="Bold"
                                       Foreground="#2E7D32" HorizontalAlignment="Center"/>
                            <TextBlock Text="公開中の教職員数" FontSize="13" Foreground="#2E7D32"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                </WrapPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="32"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>

                    <!-- 直近10回のスキャン日 -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="直近のスキャン日（最大10回）"
                                   FontSize="16" FontWeight="Medium" Margin="0,0,0,12"/>
                        <ItemsControl ItemsSource="{Binding RecentScanDates}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="14" Margin="0,0,0,6"
                                               Foreground="#424242"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- 拡張子別ファイル数 -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="拡張子別ファイル数"
                                   FontSize="16" FontWeight="Medium" Margin="0,0,0,12"/>
                        <DataGrid ItemsSource="{Binding ExtensionCounts}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  BorderThickness="1" BorderBrush="#E0E0E0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="拡張子" Binding="{Binding Extension}" Width="*"/>
                                <DataGridTextColumn Header="ファイル数" Binding="{Binding Count}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ローディングオーバーレイ -->
        <Border Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="4" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>

<UserControl x:Class="OneDriveAccessGuard.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24">

                <!-- 統計カード -->
                <WrapPanel Margin="0,0,0,24">

                    <!-- 高リスク -->
                    <Border Width="180" Height="100" Margin="0,0,16,16" CornerRadius="8"
                            Background="#FFEBEE">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding HighRiskCount}" FontSize="36" FontWeight="Bold"
                                       Foreground="#C62828" HorizontalAlignment="Center"/>
                            <TextBlock Text="高リスク" FontSize="13" Foreground="#B71C1C"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 中リスク -->
                    <Border Width="180" Height="100" Margin="0,0,16,16" CornerRadius="8"
                            Background="#FFF3E0">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding MediumRiskCount}" FontSize="36" FontWeight="Bold"
                                       Foreground="#E65100" HorizontalAlignment="Center"/>
                            <TextBlock Text="中リスク" FontSize="13" Foreground="#BF360C"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 低リスク -->
                    <Border Width="180" Height="100" Margin="0,0,16,16" CornerRadius="8"
                            Background="#FFF8E1">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding LowRiskCount}" FontSize="36" FontWeight="Bold"
                                       Foreground="#F57F17" HorizontalAlignment="Center"/>
                            <TextBlock Text="低リスク" FontSize="13" Foreground="#F57F17"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 合計 -->
                    <Border Width="180" Height="100" Margin="0,0,16,16" CornerRadius="8"
                            Background="#E3F2FD">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="{Binding TotalItemsCount}" FontSize="36" FontWeight="Bold"
                                       Foreground="#1565C0" HorizontalAlignment="Center"/>
                            <TextBlock Text="合計共有アイテム" FontSize="13" Foreground="#1565C0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- 高リスクアイテム一覧 -->
                <TextBlock Text="高リスク共有アイテム（最新10件）"
                           FontSize="16" FontWeight="Medium" Margin="0,0,0,12"/>

                <DataGrid ItemsSource="{Binding RecentHighRiskItems}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="1" BorderBrush="#E0E0E0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ファイル名" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="所有者" Binding="{Binding OwnerDisplayName}" Width="160"/>
                        <DataGridTextColumn Header="サイズ (KB)" Width="100"
                                            Binding="{Binding SizeBytes, StringFormat={}{0:N0}}"/>
                        <DataGridTextColumn Header="最終更新" Width="140"
                                            Binding="{Binding LastModified, StringFormat={}{0:yyyy/MM/dd HH:mm}}"/>
                        <DataGridHyperlinkColumn Header="URL" Binding="{Binding WebUrl}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>

            </StackPanel>
        </ScrollViewer>

        <!-- ローディングオーバーレイ -->
        <Border Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ProgressBar IsIndeterminate="True" Width="200" Height="4" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>

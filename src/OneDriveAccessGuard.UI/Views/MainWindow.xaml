<Window x:Class="OneDriveAccessGuard.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:OneDriveAccessGuard.UI.ViewModels"
        xmlns:views="clr-namespace:OneDriveAccessGuard.UI.Views"
        xmlns:conv="clr-namespace:OneDriveAccessGuard.UI.Converters"
        Title="OneDrive AccessGuard"
        Height="720" Width="1280"
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.Resources>
        <conv:PageKeyToVisibilityConverter x:Key="PageKeyToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== 左サイドバー ===== -->
        <Border Grid.Column="0"
                Background="#1E2F6B">
            <DockPanel>
                <!-- アプリタイトル -->
                <Border DockPanel.Dock="Top"
                        Padding="16,20"
                        Background="#1A237E">
                    <StackPanel>
                        <TextBlock Text="OneDrive"
                                   Foreground="White" FontSize="13" Opacity="0.8"/>
                        <TextBlock Text="AccessGuard"
                                   Foreground="White" FontSize="18" FontWeight="Bold"/>
                        <TextBlock Text="v1.0.0"
                                   Foreground="White" FontSize="10" Opacity="0.5" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- サインインユーザー情報 -->
                <Border DockPanel.Dock="Top"
                        Padding="16,12"
                        Background="#283593">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Account"
                                                 Foreground="White" Width="20" Height="20"
                                                 VerticalAlignment="Center"/>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="{Binding SignedInUserName}"
                                       Foreground="White" FontSize="11" FontWeight="Medium"/>
                            <TextBlock Text="{Binding SignedInUserEmail}"
                                       Foreground="White" FontSize="10" Opacity="0.7"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ナビゲーションメニュー -->
                <ListBox DockPanel.Dock="Top"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavItem}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="0,8,0,0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="16,10">
                                <materialDesign:PackIcon Kind="{Binding Icon}"
                                                         Foreground="#FFFFFF" Width="20" Height="20"
                                                         VerticalAlignment="Center"
                                                         Opacity="1"/>
                                <TextBlock Text="{Binding Label}"
                                           Foreground="#FFFFFF" FontSize="13"
                                           FontWeight="Regular"
                                           Margin="12,0,0,0" VerticalAlignment="Center"
                                           Opacity="1"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                            BorderThickness="0">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#3F51B5"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#3949AB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                    </ListBox.ItemContainerStyle>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- ===== メインコンテンツ ===== -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- トップバー -->
            <Border Grid.Row="0"
                    Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                <DockPanel Margin="24,0">
                    <TextBlock DockPanel.Dock="Left"
                               Text="{Binding CurrentPageTitle}"
                               FontSize="18" FontWeight="Medium"
                               VerticalAlignment="Center"/>

                </DockPanel>
            </Border>

            <!-- コンテンツ領域（ページ切替） -->
            <Grid Grid.Row="1">
                <views:DashboardView DataContext="{Binding DashboardVm}"
                                     Visibility="{Binding CurrentPageKey, Converter={StaticResource PageKeyToVisibilityConverter}, ConverterParameter=dashboard}"/>
                <views:ScanView DataContext="{Binding ScanVm}"
                                Visibility="{Binding CurrentPageKey, Converter={StaticResource PageKeyToVisibilityConverter}, ConverterParameter=scan}"/>
                <views:SharedItemsView DataContext="{Binding SharedItemsVm}"
                                       Visibility="{Binding CurrentPageKey, Converter={StaticResource PageKeyToVisibilityConverter}, ConverterParameter=files}"/>
                <views:SettingsView DataContext="{Binding SettingsVm}"
                                    Visibility="{Binding CurrentPageKey, Converter={StaticResource PageKeyToVisibilityConverter}, ConverterParameter=settings}"/>
            </Grid>
        </Grid>
    </Grid>
</Window>

<UserControl x:Class="OneDriveAccessGuard.UI.Views.ScanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 上部コントロールエリア -->
        <StackPanel Grid.Row="0">

            <TextBlock Text="OneDrive スキャン" FontSize="20" FontWeight="Medium" Margin="0,0,0,24"/>

            <!-- プログレスバー -->
            <ProgressBar Value="{Binding ProgressPercent}" Maximum="100"
                         Height="8" Margin="0,0,0,8"/>

            <!-- メッセージ -->
            <TextBlock Text="{Binding ProgressMessage}"
                       FontSize="13" Foreground="#616161" Margin="0,0,0,16"/>

            <!-- 検出件数 -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="検出アイテム数:" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding FoundItemsCount}" FontSize="24" FontWeight="Bold"
                           Foreground="#1565C0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- オプション -->
            <CheckBox Content="ゲストアカウントは除く"
                      IsChecked="{Binding ExcludeGuests}"
                      IsEnabled="{Binding CanCancel, Converter={StaticResource InverseBooleanConverter}}"
                      Margin="0,0,0,12" FontSize="14"/>

            <!-- アカウント名フィルター -->
            <TextBox Text="{Binding AccountFilter, UpdateSourceTrigger=PropertyChanged}"
                     IsEnabled="{Binding CanCancel, Converter={StaticResource InverseBooleanConverter}}"
                     materialDesign:HintAssist.Hint="アカウント名（空白の場合は全ユーザーを対象）"
                     materialDesign:HintAssist.IsFloating="True"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Width="360" HorizontalAlignment="Left"
                     Margin="0,0,0,16" FontSize="14"/>

            <!-- ボタン -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <Button Content="スキャン開始"
                        Command="{Binding StartScanCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#1565C0" Foreground="White"
                        Padding="24,8" Margin="0,0,12,0"/>

                <Button Content="キャンセル"
                        Command="{Binding CancelScanCommand}"
                        IsEnabled="{Binding CanCancel}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Padding="24,8"/>
            </StackPanel>

        </StackPanel>

        <!-- 検出アイテム一覧 -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding ScannedItems}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  SelectionMode="Single"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto"
                  materialDesign:DataGridAssist.CellPadding="8 4 8 4"
                  materialDesign:DataGridAssist.ColumnHeaderPadding="8 4 8 4">

            <DataGrid.Columns>

                <DataGridTextColumn Header="オーナー名"
                                    Binding="{Binding OwnerDisplayName}"
                                    Width="160"/>

                <DataGridTextColumn Header="ファイル名"
                                    Binding="{Binding Name}"
                                    Width="200"/>

                <DataGridTemplateColumn Header="リンク URL" Width="280">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Hyperlink NavigateUri="{Binding WebUrl}"
                                           RequestNavigate="Hyperlink_RequestNavigate">
                                    <TextBlock Text="{Binding WebUrl}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="260"/>
                                </Hyperlink>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="作成日"
                                    Binding="{Binding CreatedDateTime, StringFormat={}{0:yyyy/MM/dd}}"
                                    Width="100"/>

                <DataGridTextColumn Header="更新日"
                                    Binding="{Binding LastModified, StringFormat={}{0:yyyy/MM/dd}}"
                                    Width="100"/>

            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</UserControl>

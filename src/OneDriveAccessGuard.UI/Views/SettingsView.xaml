<UserControl x:Class="OneDriveAccessGuard.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32" MaxWidth="560" HorizontalAlignment="Left">

            <TextBlock Text="Azure AD 接続設定"
                       FontSize="20" FontWeight="Medium" Margin="0,0,0,8"/>
            <TextBlock Text="設定はレジストリ (HKCU\Software\OneDriveAccessGuard) に保存されます。"
                       FontSize="12" Foreground="#757575" Margin="0,0,0,32"/>

            <!-- Client ID -->
            <TextBox Text="{Binding ClientId, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Application (Client) ID"
                     materialDesign:HintAssist.HelperText="Azure ポータルのアプリ登録で確認できます"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,20"/>

            <!-- Tenant ID -->
            <TextBox Text="{Binding TenantId, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="Directory (Tenant) ID"
                     materialDesign:HintAssist.HelperText="Azure ポータルのテナント情報で確認できます"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,20"/>

            <!-- Certificate Thumbprint -->
            <TextBox Text="{Binding CertificateThumbprint, UpdateSourceTrigger=PropertyChanged}"
                     materialDesign:HintAssist.Hint="証明書 Thumbprint"
                     materialDesign:HintAssist.HelperText="ローカルの証明書ストア (CurrentUser\My) にインストールされた証明書の Thumbprint"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     FontFamily="Consolas" FontSize="13"
                     Margin="0,0,0,32"/>

            <!-- 保存ボタン -->
            <Button Content="保存"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#1565C0" Foreground="White"
                    Padding="32,6" HorizontalAlignment="Left"/>

            <!-- ステータスメッセージ -->
            <TextBlock Text="{Binding StatusMessage}"
                       Margin="0,16,0,0" FontSize="13">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#C62828"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSuccess}" Value="True">
                                <Setter Property="Foreground" Value="#2E7D32"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

        </StackPanel>
    </ScrollViewer>
</UserControl>

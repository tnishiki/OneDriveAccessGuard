<UserControl x:Class="OneDriveAccessGuard.UI.Views.SharedItemsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Loaded="UserControl_Loaded">

    <DockPanel>

        <!-- フィルターバー -->
        <Border DockPanel.Dock="Top"
                Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="ファイル名・所有者で絞り込み"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="280" Margin="0,0,16,0"/>

                <Button Content="一括削除（高リスク）"
                        Command="{Binding RevokeAllHighRiskCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        BorderBrush="#C62828" Foreground="#C62828"
                        Padding="16,6" Margin="0,0,8,0"/>

                <Button Content="更新"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Padding="16,6"/>
            </StackPanel>
        </Border>

        <!-- ステータスバー -->
        <Border DockPanel.Dock="Bottom"
                Background="#FAFAFA" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0"
                Padding="16,6">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#757575"/>
        </Border>

        <!-- データグリッド -->
        <DataGrid ItemsSource="{Binding DisplayItems}"
                  SelectedItem="{Binding SelectedItem}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ファイル名" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="所有者" Binding="{Binding OwnerDisplayName}" Width="160"/>
                <DataGridTextColumn Header="リスク" Binding="{Binding RiskLevel}" Width="80"/>
                <DataGridTextColumn Header="共有種別"
                                    Binding="{Binding Permissions[0].SharingType}" Width="120"/>
                <DataGridTextColumn Header="最終更新" Width="140"
                                    Binding="{Binding LastModified, StringFormat={}{0:yyyy/MM/dd HH:mm}}"/>
                <DataGridTemplateColumn Header="操作" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="削除"
                                    Command="{Binding DataContext.RevokePermissionsCommand,
                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    BorderBrush="#C62828" Foreground="#C62828"
                                    Padding="8,2" FontSize="11"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</UserControl>
